{
  "name": "opencode-sdd-engram-manage",
  "version": "1.3.2",
  "description": "Interactive SDD model selection and profile management for opencode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j0k3r-dev-rgl/sdd-engram-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/j0k3r-dev-rgl/sdd-engram-plugin/issues"
  },
  "homepage": "https://github.com/j0k3r-dev-rgl/sdd-engram-plugin#readme",
  "license": "MIT",
  "type": "module",
  "main": "./dist/tui.js",
  "exports": {
    "./tui": {
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fallback": "node ./scripts/test-fallback.ts",
    "examples": "node ./scripts/run-examples.ts",
    "orchestrator:fallback:check": "node ./scripts/ensure-orchestrator-fallback-policy.ts --check",
    "orchestrator:fallback:apply": "node ./scripts/ensure-orchestrator-fallback-policy.ts",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "esbuild-plugin-solid": "^0.6.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.29",
    "@opentui/core": ">=0.2.0 <1",
    "@opentui/solid": ">=0.2.0 <1",
    "solid-js": "1.9.12"
  },
  "engines": {
    "node": ">=24 <25",
    "opencode": ">=1.3.13"
  }
}
